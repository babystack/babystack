{
  "name": "users-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Example app — a real Express + Drizzle + MySQL API whose Vitest suite runs against fresh, seeded, isolated real MySQL via babystack, with zero test-code lifecycle. The definition-of-done proof for the Phase-0 wedge.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "node db/migrate.mjs",
    "db:seed": "node db/seed.mjs"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "mysql2": "^3.11.0"
  },
  "devDependencies": {
    "@babystack/core": "workspace:*",
    "@babystack/mysql": "workspace:*",
    "@babystack/vitest": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
