{
  "name": "@babystack/mysql",
  "version": "0.1.0",
  "type": "module",
  "description": "babystack real-MySQL engine adapter — provision, build a seeded mysqldump baseline, hand each worker a fresh leased database.",
  "license": "Apache-2.0",
  "author": "Sharvil Kadam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babystack/babystack.git",
    "directory": "packages/mysql"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@babystack/core": "workspace:*",
    "@babystack/docker": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/babystack/babystack/tree/main/packages/mysql#readme",
  "bugs": {
    "url": "https://github.com/babystack/babystack/issues"
  },
  "engines": {
    "node": ">=22"
  }
}
