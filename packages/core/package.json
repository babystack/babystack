{
  "name": "@babystack/core",
  "version": "0.1.0",
  "type": "module",
  "description": "babystack core: config, lifecycle, the EngineAdapter seam + Lease/Pool, injected Clock/CommandRunner ports, invalidation, env injection. Pure core — no I/O.",
  "license": "Apache-2.0",
  "author": "Sharvil Kadam",
  "homepage": "https://github.com/babystack/babystack/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/babystack/babystack.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "pnpm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --dir tests/integration --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "bugs": {
    "url": "https://github.com/babystack/babystack/issues"
  },
  "engines": {
    "node": ">=22"
  }
}
